<?xml version="1.0" encoding="utf-8"?>
<!--
  시간표 한 row.
  포맷: [요일] 시간  과목명  장소
  예시: [월] 14:00~14:50  운영체제  공학관 301
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="16dp"
    android:paddingVertical="10dp">

    <TextView
        android:id="@+id/scheduleDayChip"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:background="?attr/colorPrimaryContainer"
        android:gravity="center"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:text="월"
        xmlns:tools="http://schemas.android.com/tools" />

    <TextView
        android:id="@+id/scheduleTimeText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:textSize="14sp"
        app:layout_constraintStart_toEndOf="@id/scheduleDayChip"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="14:00~14:50"
        xmlns:tools="http://schemas.android.com/tools" />

    <TextView
        android:id="@+id/scheduleSubjectText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="2dp"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintStart_toEndOf="@id/scheduleDayChip"
        app:layout_constraintTop_toBottomOf="@id/scheduleTimeText"
        app:layout_constraintEnd_toStartOf="@id/scheduleLocationText"
        tools:text="운영체제"
        xmlns:tools="http://schemas.android.com/tools" />

    <TextView
        android:id="@+id/scheduleLocationText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textColor="?android:attr/textColorSecondary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="@id/scheduleSubjectText"
        tools:text="공학관 301"
        xmlns:tools="http://schemas.android.com/tools" />

</androidx.constraintlayout.widget.ConstraintLayout>
